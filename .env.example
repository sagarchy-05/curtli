# Database Configuration
POSTGRES_DB=curtli
DB_USERNAME=postgres
DB_PASSWORD=postgres
HOST_DB_PORT=5433

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
HOST_REDIS_PORT=6379
# Client-side command timeout. Must be ≥ STREAM_BLOCK_MILLIS so blocking
# XREADGROUP polls aren't killed by Lettuce before the server replies.
SPRING_DATA_REDIS_TIMEOUT=5000

# App Configuration
CURTLI_BASE_URL=http://localhost:8080
HOST_APP_PORT=8080

# Salt used when hashing client IPs into ClickEvent.ipHash. Anyone with this
# value AND the click_events stream can rainbow-table IPs back, so PRODUCTION
# MUST OVERRIDE this with a long random string — e.g.  openssl rand -hex 32
# The value below is intentionally obvious so it stands out in `docker exec
# env` output if it ever leaks into prod by accident.
CURTLI_IP_HASH_SECRET=dev-only-override-this-in-production

# Rate Limiting & Caching
# CURTLI_RATE_LIMIT_PER_MINUTE is the per-IP cap on /api/shorten. The Lua
# script derives the bucket TTL from this value (ceil(N / (N/60)) + 5),
# so dropping it during an attack also shortens key lifetime as a side effect.
# CURTLI_CACHE_TTL_SECONDS bounds the link:{code} cache TTL (a cached entry
# never outlives the link's own expiry — this is the upper bound).
CURTLI_RATE_LIMIT_PER_MINUTE=10
CURTLI_CACHE_TTL_SECONDS=10800

# Async Analytics Thread Pool limits
# Tuned for a 2 vCPU host (t4g.small). Core matches vCPU count so we don't
# pay for threads that can't run in parallel; max gives burst headroom for
# click spikes; queue absorbs short bursts before the RejectedExecutionHandler
# starts silently dropping events (which is the fire-and-forget design).
ASYNC_CORE_POOL=2
ASYNC_MAX_POOL=8
ASYNC_QUEUE_CAPACITY=2000

# Redis Stream Consumer Tuning
# Large batch size is intentional — the aggregator UPSERTs by
# (link_id, bucket_hour), so more events per tick = better collapse ratio
# and fewer DB round-trips. BLOCK_MILLIS must stay < SPRING_DATA_REDIS_TIMEOUT.
STREAM_POLL_DELAY=1000
STREAM_BATCH_SIZE=1500
STREAM_BLOCK_MILLIS=250

# Max URLs accepted in a single /api/shorten request
BULK_BATCH_SIZE=20

# HikariCP (Postgres) Connection Pool
# Sized for a single-instance deployment against Postgres with
# max_connections=50 (see docker-compose.prod.yml). Each idle connection
# costs ~2–5 MB on the Postgres side, so the pool is intentionally lean —
# curtli is cache-heavy and rarely sees more than a handful of concurrent
# DB queries in flight (one per shorten + one per consumer tick).
DB_POOL_MAX=10
DB_POOL_MIN_IDLE=2
DB_POOL_CONN_TIMEOUT=10000      # ms — fail fast under saturation
DB_POOL_IDLE_TIMEOUT=600000     # 10 min — release unused connections
DB_POOL_MAX_LIFETIME=1800000    # 30 min — recycle before Postgres may kill the connection
DB_POOL_LEAK_DETECTION=30000    # 30 s — log warning if a connection isn't returned